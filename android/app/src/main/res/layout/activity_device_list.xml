<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="8dp">
        <Button android:id="@+id/refreshButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Refresh" />
        <Button android:id="@+id/settingsButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Settings" />
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/deviceRecycler" android:layout_width="match_parent" android:layout_height="match_parent" />
</LinearLayout>
